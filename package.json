{
  "name": "boekhouding-engine",
  "version": "2.0.0",
  "description": "Google Apps Script boekhoudprogramma",
  "private": true,
  "scripts": {
    "lint": "eslint 'src/**/*.gs'",
    "lint:fix": "eslint 'src/**/*.gs' --fix",
    "lint:changed": "git diff --name-only HEAD | grep '\\.gs$' | xargs -r eslint",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --testPathPattern='tests/unit' --passWithNoTests",
    "test:integration": "jest --testPathPattern='tests/integration' --passWithNoTests",
    "test:flow": "jest --testNamePattern",
    "test:watch": "jest --watch --passWithNoTests",
    "index": "node scripts/symbol-index.js",
    "impact": "node scripts/impact.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.gs": "eslint"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "eslint": "^9.27.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2"
  }
}
